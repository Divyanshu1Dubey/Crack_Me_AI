# Backend localhost + Supabase local stack
# Copy this to backend/.env and adjust secrets as needed.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Supabase local Postgres (from `npx supabase start`)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DB_CONNECT_TIMEOUT=5
ENABLE_RUNTIME_SCHEMA_REPAIR=true

# Email (optional for localhost)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CrackCMS <noreply@localhost>
EMAIL_TIMEOUT=20

# Optional AI keys
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GITHUB_TOKEN=
HUGGINGFACE_API_KEY=
AIML_API_KEY=
MISTRAL_API_KEY=
NVIDIA_MISTRAL_API_KEY=
