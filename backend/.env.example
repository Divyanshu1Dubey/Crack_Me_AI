# Core Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origin for links and CORS/CSRF
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Database (Supabase Postgres)
# Replace [YOUR-PASSWORD] with your Supabase database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ryuvcdthjnxyetdyjbph.supabase.co:5432/postgres

# Optional: mirror Django registrations into Supabase Auth (auth.users)
SUPABASE_AUTH_MIRROR_ENABLED=false
SUPABASE_URL=https://ryuvcdthjnxyetdyjbph.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Email (Gmail SMTP for password reset emails)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=CrackCMS <your-email@gmail.com>
EMAIL_TIMEOUT=20

