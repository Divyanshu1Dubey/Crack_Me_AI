# Frontend localhost + Supabase local auth
# Copy this to frontend/.env.local

# Django backend API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_FALLBACK_URL=http://localhost:8000/api
NEXT_PUBLIC_USE_API_PROXY=false

# Supabase local (from `npx supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-anon-key

# Enable Supabase auth in UI
NEXT_PUBLIC_AUTH_PROVIDER=supabase
NEXT_PUBLIC_USE_SUPABASE_AUTH=true
